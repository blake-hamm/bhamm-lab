{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":gitSignOff",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)"
  ],
  "automerge": false,
  "pinDigests": false,
  "labels": ["dependencies"],
  "kubernetes": {
    "managerFilePatterns": [
      "/^kubernetes/manifests/.+\\.yaml$/"
    ]
  },
  "argocd": {
    "managerFilePatterns": [
      "/^kubernetes/manifests/.+\\.yaml$/"
    ]
  }
}
